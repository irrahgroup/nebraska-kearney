{
  "name": "@z-api/n8n-nodes-zapi",
  "version": "0.1.2",
  "description": "n8n community node to integrate with Z-API (WhatsApp messaging).",
  "license": "MIT",
  "homepage": "https://github.com/irrahgroup/nebraska-kearney",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "z-api",
    "whatsapp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/irrahgroup/nebraska-kearney.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "build:npm": "tsup",
    "rise": "npm version patch && npm publish",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/ZapiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Zapi/Zapi.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "@types/node": "^24.9.1",
    "eslint": "9.32.0",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
